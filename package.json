{
  "name": "pikngo",
  "version": "1.0.0",
  "description": "Welcome to the PikNGo Backend project. This repository contains the core services for the PikNGo application.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-frontend\"",
    "dev-backend": "cd user-service && mvnw spring-boot:run",
    "dev-frontend": "cd frontend && npm run dev",
    "start": "concurrently \"npm run start-backend\" \"npm run dev-frontend\"",
    "start-backend": "cd user-service && java -jar target/user-service-0.0.1-SNAPSHOT.jar"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mkdevx006/PikNGo.git"
  },
